# ============================================================
#  Hermes Control Panel — configuración
# ============================================================

# Contraseña de acceso al panel (OBLIGATORIO en producción).
# Si se deja vacío, el panel arranca en modo demo con la
# contraseña "hermes".
HERMES_CONTROL_PASSWORD=hermes

# Secreto para firmar las sesiones (cámbialo por una cadena aleatoria larga).
HERMES_CONTROL_SECRET=cambia-este-secreto-por-uno-aleatorio

# Puerto del servidor del panel.
PORT=10274

# Directorio de estado de Hermes (config.yaml, logs, skills...).
HERMES_CONTROL_HOME=~/.hermes

# Raíz de proyectos que el panel puede explorar en la pestaña "Archivos".
HERMES_PROJECTS_ROOT=

# Ruta o nombre del binario del CLI de Hermes (por defecto: hermes).
HERMES_BIN=hermes

# Endpoint OpenAI-compatible expuesto por `hermes serve` (opcional).
# Si se define, el chat del panel lo usará para streaming real.
# Ej: http://localhost:9100/v1
HERMES_API_URL=

# Clave para el endpoint anterior (si aplica).
HERMES_API_KEY=

# Fuerza el modo demo aunque exista el CLI de Hermes (true/false).
HERMES_DEMO=false
